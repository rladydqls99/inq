{
  "name": "inq",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @inq/db prisma generate",
    "db:migrate": "pnpm --filter @inq/db db:ensure && pnpm --filter @inq/db prisma migrate deploy",
    "docker:build": "docker compose -f deploy/docker-compose.prod.yml build",
    "docker:deploy:build": "docker compose -f deploy/docker-compose.prod.yml build",
    "docker:deploy:down": "docker compose -f deploy/docker-compose.prod.yml down",
    "docker:deploy:up": "docker compose -f deploy/docker-compose.prod.yml up -d",
    "docker:down": "docker compose -f deploy/docker-compose.prod.yml down",
    "docker:up": "docker compose -f deploy/docker-compose.prod.yml up",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --parallel dev"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/eslint-plugin-query": "^5.101.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0"
  }
}
