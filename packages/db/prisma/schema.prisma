generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Deck {
  id               String        @id @default(cuid())
  title            String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cards            Card[]
  sourceChallenges Challenge[]   @relation("ChallengeSourceDeck")
  deckRunState     DeckRunState?
}

model Card {
  id                   String          @id @default(cuid())
  deckId               String
  deck                 Deck            @relation(fields: [deckId], references: [id], onDelete: Cascade)
  segments             Json
  studyViewCount       Int             @default(0)
  lastStudiedAt        DateTime?
  version              Int             @default(1)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  sourceChallengeCards ChallengeCard[] @relation("ChallengeCardSource")

  @@index([deckId])
}

model Challenge {
  id                  String                 @id @default(cuid())
  name                String
  sourceDeckId        String?
  sourceDeck          Deck?                  @relation("ChallengeSourceDeck", fields: [sourceDeckId], references: [id], onDelete: SetNull)
  sourceDeckTitle     String
  status              String                 @default("active")
  answerMode          String                 @default("manual")
  reviewIntervalsDays Json
  maxStage            Int
  completedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  cards               ChallengeCard[]
  cardStates          ChallengeCardState[]
  answerEvents        ChallengeAnswerEvent[]
  runSessions         ChallengeRunSession[]

  @@index([sourceDeckId])
  @@index([status])
}

model ChallengeCard {
  id               String                 @id @default(cuid())
  challengeId      String
  challenge        Challenge              @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  sourceDeckCardId String?
  sourceDeckCard   Card?                  @relation("ChallengeCardSource", fields: [sourceDeckCardId], references: [id], onDelete: SetNull)
  segments         Json
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  state            ChallengeCardState?
  answerEvents     ChallengeAnswerEvent[]

  @@unique([challengeId, sourceDeckCardId])
  @@index([challengeId])
  @@index([sourceDeckCardId])
}

model ChallengeCardState {
  id                 String                 @id @default(cuid())
  challengeId        String
  challenge          Challenge              @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeCardId    String                 @unique
  challengeCard      ChallengeCard          @relation(fields: [challengeCardId], references: [id], onDelete: Cascade)
  stage              Int                    @default(0)
  challengeViewCount Int                    @default(0)
  dueAt              DateTime?
  lastChallengedAt   DateTime?
  result             String?
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  answerEvents       ChallengeAnswerEvent[]

  @@index([challengeId, dueAt])
}

model ChallengeAnswerEvent {
  id              String             @id @default(cuid())
  challengeId     String
  challenge       Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  stateId         String
  state           ChallengeCardState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  challengeCardId String
  challengeCard   ChallengeCard      @relation(fields: [challengeCardId], references: [id], onDelete: Cascade)
  sessionCardId   String
  finalResult     String
  previousStage   Int
  nextStage       Int?
  answeredAt      DateTime           @default(now())

  @@index([challengeId])
  @@index([stateId])
  @@index([challengeCardId])
  @@index([sessionCardId])
}

model ChallengeRunSession {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  status      String    @default("active")
  cursor      Int       @default(0)
  queue       Json
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([challengeId])
  @@index([status])
}

model DeckRunState {
  id          String    @id @default(cuid())
  deckId      String    @unique
  deck        Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cursor      Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model PinSettings {
  id                    String   @id @default(cuid())
  pinHash               String
  sessionsInvalidatedAt DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
